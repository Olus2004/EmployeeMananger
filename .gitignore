## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for Visual Studio 2022.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv][Ss][Pp][Ss][Cc][Cc]
[Vv][Ss][Ss][Ss][Cc]
.builds
*.deployproj

# WCF Test Client grace periods
*.svclog
*.svcmap
*.svclog

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if using tasks.json or launch.json
#.vscode/

# Output of dotnet publish
[Pp]ublish/

# ReSharper is a 3rd party add-in for Visual Studio
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustTrace is a 3rd party add-in for Visual Studio
_JustTrace*/

# TeamCity is a build server
_TeamCity*/

# DotCover is a 3rd party add-in for Visual Studio
_dotCover*/

# AxoCover is a 3rd party add-in for Visual Studio
.axoCover/*
/_PyCharm*/

# JetBrains Rider
.idea/

# Visual Studio Code
.vscode/

# OpenCover is a 3rd party add-in for Visual Studio
opencover/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator project
DocProject/buildhelp/
DocProject/Help/*.mcgh

# NUnit
/*.TestResult.xml
/*.VisualState.xml

# Leadit (CHM creation)
_Leadit.??

# Guidance Automation Toolkit
*.gpState

# MyGet
root/*.ps1

# Paket dependency manager
.paket/
paket-files/

# Roslyn Analyzers
*.mindump

# EF Core migrations
#*.Design.cs

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Mac OS files
.DS_Store

# User-specific files (Rider)
.idea/

# Backup files
*.bak
*.sql
